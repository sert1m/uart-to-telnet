{
    "uart": {
        "portName": "/dev/ttyUSB0",
        "baudRate": 115200,
        "dataBits": 8,
        "parity": "none",
        "stopBits": 1
    },
    "telnetPort": 2323,
    "logDir": "./logs",
    "networkInterface": "wlp0s20f3",
    "displayTimeoutMs": 60000,
    "commandSequence": {
        "rules": [
            { "trigger": "login:", "response": "root" },
            { "trigger": "#", "response": "journalctl -f -o short-monotonic" }
        ],
        "postCommands": [],
        "lineEnding": "\n",
        "promptTimeoutMs": 0
    }
}
